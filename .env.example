# Required
ACP_WALLET_ADDRESS=0xYourSmartAccountAddress
ACP_PRIVATE_KEY=0xYourPrivateKey

# Provider type: "privy | alchemy" (default privy)
# ACP_PROVIDER_TYPE=privy

# For alchemy provider
# ACP_ENTITY_ID=1

# For privy provider (set ACP_PROVIDER_TYPE=privy)
# ACP_WALLET_ID=your-privy-wallet-id
# ACP_SIGNER_PRIVATE_KEY=your-privy-signer-key

# Socket server URL (default: http://localhost:3000)
# ACP_SOCKET_SERVER_URL=http://localhost:3000

# Override ACP contract address (default: Base Sepolia)
# ACP_CONTRACT_ADDRESS=0x2A58201D603eDFb4F7B0d65edCeFea79E6368541
