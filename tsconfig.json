{
  "compilerOptions": {
    "rootDir": ".",
    "outDir": "dist",
    "module": "es2022",
    "moduleResolution": "bundler",
    "target": "es2022",
    "types": ["node"],
    "sourceMap": true,
    "declaration": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "moduleDetection": "force"
  },
  "include": ["bin/**/*", "src/**/*"]
}
